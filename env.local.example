# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Anthropic — requires Opus 4.7 access for vision extraction
ANTHROPIC_API_KEY=sk-ant-...

# Storage bucket name
SUPABASE_STORAGE_BUCKET=documents

# OAuth providers
# Set to "true" to render the "Continue with Apple" button on /signin.
# Requires the Apple provider to also be enabled in Supabase dashboard
# (Authentication → Providers → Apple) with Services ID / Team ID / Key ID / private key.
NEXT_PUBLIC_APPLE_OAUTH_ENABLED=true
